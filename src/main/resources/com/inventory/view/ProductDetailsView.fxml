<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.inventory.controller.ProductDetailsController"
      spacing="15" style="-fx-padding: 20;">

    <Label text="Product Details" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="10">
        <Label text="ID:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <Label fx:id="idLabel" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Name:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <Label fx:id="nameLabel" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Category:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <Label fx:id="categoryLabel" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Quantity:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <Label fx:id="quantityLabel" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Price:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <Label fx:id="priceLabel" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
    </GridPane>

    <Label text="Delivery History" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

    <TableView fx:id="deliveriesTable" prefHeight="200">
        <columns>
            <TableColumn fx:id="deliveryDateColumn" text="Date" prefWidth="150"/>
            <TableColumn fx:id="deliveryQuantityColumn" text="Quantity" prefWidth="100"/>
            <TableColumn fx:id="deliveryPriceColumn" text="Price" prefWidth="100"/>
        </columns>
    </TableView>

    <HBox spacing="10">
        <Button text="Close" onAction="#handleClose"/>
        <Button text="Add Stock" onAction="#handleAddStock"/>
        <Button text="Edit" onAction="#handleEdit"/>
    </HBox>

</VBox>