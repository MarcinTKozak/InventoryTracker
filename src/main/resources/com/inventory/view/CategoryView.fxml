<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.inventory.controller.CategoryController"
      spacing="15" style="-fx-padding: 20;">

    <Label text="Manage Categories" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="10">
        <Label text="Main Category:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <HBox spacing="5" GridPane.rowIndex="0" GridPane.columnIndex="1">
            <ComboBox fx:id="mainCategoryComboBox" promptText="Select main category" prefWidth="200"/>
            <Button text="+" onAction="#handleAddMainCategory"/>
        </HBox>

        <Label text="Subcategory:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <HBox spacing="5" GridPane.rowIndex="1" GridPane.columnIndex="1">
            <ComboBox fx:id="subCategoryComboBox" promptText="Select subcategory" prefWidth="200"/>
            <Button text="+" onAction="#handleAddSubCategory"/>
        </HBox>

        <Label text="Variant:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <HBox spacing="5" GridPane.rowIndex="2" GridPane.columnIndex="1">
            <ComboBox fx:id="variantComboBox" promptText="Select variant (optional)" prefWidth="200"/>
            <Button text="+" onAction="#handleAddVariant"/>
        </HBox>
    </GridPane>

    <HBox spacing="10">
        <Button text="Close" onAction="#handleClose"/>
    </HBox>

</VBox>