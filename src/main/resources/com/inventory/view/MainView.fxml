<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.inventory.controller.MainController"
            prefHeight="600.0" prefWidth="900.0">

    <top>
        <VBox spacing="10" style="-fx-padding: 10;">
            <Label text="Inventory Tracker" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
            <HBox spacing="10">
                <TextField fx:id="nameField" promptText="Product name"/>
                <TextField fx:id="categoryField" promptText="Category"/>
                <TextField fx:id="quantityField" promptText="Quantity"/>
                <TextField fx:id="priceField" promptText="Price"/>
                <Button text="Add Product" onAction="#handleAddProduct"/>
                <Button text="Update" onAction="#handleUpdateProduct"/>
                <Button text="Delete" onAction="#handleDeleteProduct"/>
                <Button text="Reset" onAction="#handleReset"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <TableView fx:id="productTable" style="-fx-padding: 10;">
            <columns>
                <TableColumn fx:id="idColumn" text="ID" prefWidth="50"/>
                <TableColumn fx:id="nameColumn" text="Name" prefWidth="200"/>
                <TableColumn fx:id="categoryColumn" text="Category" prefWidth="150"/>
                <TableColumn fx:id="quantityColumn" text="Quantity" prefWidth="100"/>
                <TableColumn fx:id="priceColumn" text="Price" prefWidth="100"/>
            </columns>
        </TableView>
    </center>

</BorderPane>